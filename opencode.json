{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["@angdrew/opencode-hashline-plugin"],
  "agent": {
    "hashline-test": {
      "description": "Minimal smoke-test agent for hashline hash-* tools",
      "mode": "primary",
      "model": "proxy/gpt-5.1-codex-mini",
      "permission": {
        "*": "deny",
        "hash-read": "allow",
        "hash-edit": "allow",
        "hash-patch": "allow",
        "hash-write": "allow",
        "bash": "deny",
        "glob": "deny",
        "grep": "deny",
        "list": "deny"
      }
    }
  }
}
